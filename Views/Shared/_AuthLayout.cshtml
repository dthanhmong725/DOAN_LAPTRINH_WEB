<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - CyberForum</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Diễn đàn cộng đồng an ninh mạng Việt Nam")">
    <link rel="icon" href="/favicon.ico">
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- CyberForum Theme -->
    <link rel="stylesheet" href="/css/themes/cyber.css">
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
    <!-- Password strength -->
    <link rel="stylesheet" href="/css/password-strength.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="display: flex; align-items: center; justify-content: center; min-height: 100vh;">

    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
