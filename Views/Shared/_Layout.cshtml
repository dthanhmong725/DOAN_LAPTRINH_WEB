<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - CyberForum</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Diễn đàn cộng đồng an ninh mạng Việt Nam")">
    <link rel="icon" href="/favicon.ico">
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- CyberForum Theme -->
    <link rel="stylesheet" href="/css/themes/cyber.css">
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
    <!-- Notification bell -->
    <link rel="stylesheet" href="/css/notification-bell.css">
    <!-- Code highlight -->
    <link rel="stylesheet" href="/css/code-block.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @* ─── NAVBAR ─────────────────────────────────────────────────────────── *@
    <nav class="navbar">
        <a href="/" class="logo">
            <img src="/logo2-Photoroom.png" alt="CyberForum" style="height:32px;width:auto;">
        </a>

        <div class="search-box">
            <div class="search-wrapper">
                <i class="ti ti-search search-icon"></i>
                <input type="search" id="globalSearch" class="search-input"
                       placeholder="Tìm kiếm bài viết, thành viên, chủ đề..."
                       onkeyup="handleSearch(this.value)">
            </div>
        </div>

        <div class="navbar-right">
            @* Chưa đăng nhập *@
            @if (!User.Identity!.IsAuthenticated)
            {
                <div class="auth-buttons d-flex gap-2">
                    <a href="/auth/login" class="btn btn-ghost btn-nav">Đăng nhập</a>
                    <a href="/auth/register" class="btn btn-primary btn-nav">Đăng ký</a>
                </div>
            }
            else
            {
                @* Đã đăng nhập *@
                <div class="user-menu d-flex align-items-center gap-2">
                    <a href="/posts/create" class="btn btn-primary btn-nav">
                        <i class="ti ti-plus"></i> Bài mới
                    </a>

                    <button class="btn btn-ghost btn-icon" id="notificationBtn" title="Thông báo" style="position:relative;">
                        <i class="ti ti-bell"></i>
                        <span id="notificationBadge" class="notification-badge" style="display:none;">0</span>
                    </button>

                    <div style="position:relative;">
                        <button class="btn btn-ghost btn-user" id="userMenuBtn">
                            <div class="avatar avatar-sm user-avatar" id="navUserAvatar">
                                @(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <span class="user-name" id="navUserName">
                                @(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "")
                            </span>
                            <i class="ti ti-chevron-down" style="font-size:0.75rem;"></i>
                        </button>

                        <div id="userDropdown" style="display:none; position:absolute; top:calc(100% + 8px); right:0;
                             background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--radius-md);
                             padding:6px; min-width:200px; z-index:1000;">
                            <a href="/users/profile" class="nav-item" style="padding:8px 12px; display:flex; align-items:center; gap:8px;">
                                <i class="ti ti-user"></i> Hồ sơ
                            </a>
                            <a href="/reputation" class="nav-item" style="padding:8px 12px; display:flex; align-items:center; gap:8px;">
                                <i class="ti ti-star"></i> Điểm uy tín
                            </a>
                            <a href="/upload" class="nav-item" style="padding:8px 12px; display:flex; align-items:center; gap:8px;">
                                <i class="ti ti-upload"></i> Upload tài liệu
                            </a>
                            <a href="/bookmarks" class="nav-item" style="padding:8px 12px; display:flex; align-items:center; gap:8px;">
                                <i class="ti ti-bookmark"></i> Đã lưu
                            </a>
                            <a href="/users/settings" class="nav-item" style="padding:8px 12px; display:flex; align-items:center; gap:8px;">
                                <i class="ti ti-settings"></i> Cài đặt
                            </a>
                            <hr style="margin:4px 0; border-color:var(--border);">
                            <form asp-controller="AuthMvc" asp-action="Logout" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-item w-100 text-start"
                                        style="padding:8px 12px; display:flex; align-items:center; gap:8px; background:none; border:none; color:var(--accent-red); cursor:pointer;">
                                    <i class="ti ti-logout"></i> Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </nav>

    @* ─── PAGE WRAPPER ────────────────────────────────────────────────────── *@
    <div class="page-wrapper">

        @* ─── SIDEBAR ─────────────────────────────────────────────────────── *@
        <aside class="sidebar" id="sidebar">
            <nav class="nav-section">
                <a href="/" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "HomeMvc" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="ti ti-home"></i>
                    <span>Trang chủ</span>
                </a>
                <a href="/categories" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "CategoryMvc" ? "active" : "")">
                    <i class="ti ti-category"></i>
                    <span>Danh mục</span>
                </a>
                <a href="/leaderboard" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Leaderboard" ? "active" : "")">
                    <i class="ti ti-trophy"></i>
                    <span>Bảng xếp hạng</span>
                </a>
                <a href="/badges" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "BadgesMvc" ? "active" : "")">
                    <i class="ti ti-medal"></i>
                    <span>Huy hiệu</span>
                </a>
            </nav>

            <div class="nav-section">
                <div class="nav-section-title">Chủ đề</div>
                <div id="categoryNav">
                    <div class="skeleton" style="height:36px; margin-bottom:4px;"></div>
                    <div class="skeleton" style="height:36px; margin-bottom:4px;"></div>
                    <div class="skeleton" style="height:36px;"></div>
                </div>
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                <div class="nav-section">
                    <div class="nav-section-title">Truy cập nhanh</div>
                    <a href="/users/profile" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                        <i class="ti ti-user"></i><span>Hồ sơ cá nhân</span>
                    </a>
                    <a href="/upload" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                        <i class="ti ti-upload"></i><span>Quản lý upload</span>
                    </a>
                    <a href="/chat" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                        <i class="ti ti-messages"></i><span>Tin nhắn</span>
                    </a>
                    <a href="/reputation" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                        <i class="ti ti-star"></i><span>Điểm uy tín</span>
                    </a>
                    <a href="/security/logs" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                        <i class="ti ti-shield-lock"></i><span>Nhật ký bảo mật</span>
                    </a>
                </div>


                @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Admin" || User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Moderator")
                {
                    <div class="nav-section">
                        <div class="nav-section-title">Quản trị</div>
                        @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
                        {
                            <a href="/admin" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                                <i class="ti ti-settings"></i><span>Bảng quản trị</span>
                            </a>
                        }
                        <a href="/admin/moderator" class="nav-item" style="display:flex; align-items:center; gap:8px; padding:9px 16px;">
                            <i class="ti ti-shield"></i><span>Trang điều hành</span>
                        </a>
                        <form asp-controller="AuthMvc" asp-action="Logout" method="post" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-item w-100 text-start"
                                    style="padding:9px 16px; display:flex; align-items:center; gap:8px; background:none; border:none; color:var(--accent-red); cursor:pointer; margin-top:8px; border-top:1px solid var(--border);">
                                <i class="ti ti-logout"></i><span>Đăng xuất</span>
                            </button>
                        </form>
                    </div>
                }
            }
        </aside>

        @* ─── MAIN CONTENT ─────────────────────────────────────────────────── *@
        <main class="main-content">
            <div class="container">
                @RenderBody()
            </div>
        </main>
    </div>

    @* ─── SCRIPTS ─────────────────────────────────────────────────────────── *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/role-guard.js"></script>
    <script src="/js/post-renderer.js"></script>
    <script src="/js/notification-bell.js"></script>
    <script src="/js/message-bell.js"></script>
    <script src="/js/theme-manager.js"></script>
    <script src="/js/sidebar-toggle.js"></script>
    <script src="/js/site.js"></script>

    <script>
        // Load categories for sidebar
        async function loadSidebarCategories() {
            try {
                const result = await API.categories.getAll();
                if (result.success && result.data) {
                    const nav = document.getElementById('categoryNav');
                    if (nav) {
                        nav.innerHTML = result.data.map(cat => {
                            const iconName = cat.icon.startsWith('ti-') ? cat.icon : 'ti-' + cat.icon;
                            return `<a href="/categories/${cat.slug}" class="nav-item category-nav-item" data-slug="${cat.slug}"
                                       style="display:flex; align-items:center; gap:8px;">
                                        <i class="ti ${iconName}" style="color:${cat.color}; font-size:1rem;"></i>
                                        <span style="flex:1;">${cat.name}</span>
                                        <span class="badge" style="font-size:0.625rem; padding:1px 5px; background:${cat.color}22; color:${cat.color};">${cat.postCount}</span>
                                    </a>`;
                        }).join('');
                    }
                }
            } catch (e) { console.warn('Sidebar categories error:', e); }
        }

        // Search handler
        let _searchTimeout;
        function handleSearch(val) {
            clearTimeout(_searchTimeout);
            _searchTimeout = setTimeout(() => {
                if (val.length >= 3) window.location.href = `/search?q=${encodeURIComponent(val)}`;
            }, 500);
        }

        // User dropdown
        document.addEventListener('DOMContentLoaded', () => {
            const menuBtn = document.getElementById('userMenuBtn');
            const dropdown = document.getElementById('userDropdown');
            if (menuBtn && dropdown) {
                menuBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
                });
                document.addEventListener('click', () => { dropdown.style.display = 'none'; });
            }
            loadSidebarCategories();
            if (typeof NotificationBell !== 'undefined' && @(User.Identity!.IsAuthenticated ? "true" : "false")) {
                NotificationBell.init();
            }
            if (typeof MessageBell !== 'undefined' && @(User.Identity!.IsAuthenticated ? "true" : "false")) {
                MessageBell.init();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
