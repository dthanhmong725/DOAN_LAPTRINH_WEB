@{
    Layout = "_Layout";
    ViewData["Title"] = "Bảng quản trị - CyberForum";
    var adminName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Admin";
}

<section>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <div>
            <h1 style="font-size:1.5rem; display:flex; align-items:center; gap:10px; margin-bottom:4px;">
                <i class="ti ti-settings" style="color:var(--accent);"></i> Bảng quản trị
            </h1>
            <p class="text-muted" style="font-size:0.875rem;">Chào mừng, <strong>@adminName</strong></p>
        </div>
        <a href="/admin/moderator" class="btn btn-secondary">
            <i class="ti ti-shield"></i> Trang điều hành
        </a>
    </div>

    @* Tabs *@
    <div class="card" style="padding:0; margin-bottom:20px; overflow:hidden;">
        <div style="display:flex; border-bottom:1px solid var(--border); overflow-x:auto;">
            <button class="admin-tab active" data-tab="dashboard"><i class="ti ti-chart-bar"></i> Thống kê</button>
            <button class="admin-tab" data-tab="users"><i class="ti ti-users"></i> Người dùng</button>
            <button class="admin-tab" data-tab="security"><i class="ti ti-shield-lock"></i> Nhật ký</button>
            <button class="admin-tab" data-tab="permissions"><i class="ti ti-lock"></i> Phân quyền</button>
        </div>

        @* Dashboard Tab *@
        <div id="tab-dashboard" class="admin-tab-content" style="padding:20px;">
            <div id="statCards" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:14px; margin-bottom:20px;">
                <div class="skeleton" style="height:90px; border-radius:var(--radius-md);"></div>
                <div class="skeleton" style="height:90px; border-radius:var(--radius-md);"></div>
                <div class="skeleton" style="height:90px; border-radius:var(--radius-md);"></div>
                <div class="skeleton" style="height:90px; border-radius:var(--radius-md);"></div>
            </div>
            <div class="card" style="padding:16px; margin-bottom:20px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
                    <h3 style="font-size:0.9375rem; margin:0;">Tăng trưởng 14 ngày gần nhất</h3>
                    <div style="display:flex; gap:14px; font-size:0.75rem; color:var(--text-muted);">
                        <span><span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:#3fb950; margin-right:4px;"></span>Người dùng</span>
                        <span><span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:#388bfd; margin-right:4px;"></span>Bài viết</span>
                        <span><span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:#d29922; margin-right:4px;"></span>Bình luận</span>
                    </div>
                </div>
                <div style="position:relative; height:260px;"><canvas id="growthChart"></canvas></div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="card" style="padding:16px;">
                    <h3 style="font-size:0.9375rem; margin-bottom:12px;">Phân bổ vai trò</h3>
                    <div style="position:relative; height:200px; display:flex; justify-content:center;"><canvas id="roleChart"></canvas></div>
                </div>
                <div class="card" style="padding:16px;">
                    <h3 style="font-size:0.9375rem; margin-bottom:12px;">Top danh mục</h3>
                    <div id="topCategoriesList" style="display:flex; flex-direction:column; gap:10px;"></div>
                </div>
            </div>
            <div class="card" style="padding:16px; margin-top:16px;">
                <h3 style="font-size:0.9375rem; margin-bottom:12px;">Top thành viên theo uy tín</h3>
                <div id="topUsersList" style="display:flex; flex-direction:column; gap:8px;"></div>
            </div>
        </div>

        @* Users Tab *@
        <div id="tab-users" class="admin-tab-content" style="padding:20px; display:none;">
            <div style="display:flex; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
                <div style="flex:1; min-width:200px;">
                    <input type="text" id="userSearch" class="form-input" placeholder="Tìm kiếm tên đăng nhập...">
                </div>
                <select id="roleFilter" class="form-select" style="width:auto; min-width:140px;">
                    <option value="">Tất cả vai trò</option>
                    <option value="User">Người dùng</option>
                    <option value="Moderator">Điều hành viên</option>
                    <option value="Admin">Quản trị viên</option>
                </select>
                <select id="banFilter" class="form-select" style="width:auto; min-width:140px;">
                    <option value="">Tất cả</option>
                    <option value="false">Đang hoạt động</option>
                    <option value="true">Đã bị khóa</option>
                </select>
                <button class="btn btn-primary btn-sm" onclick="loadUsers(1)">
                    <i class="ti ti-search"></i> Tìm kiếm
                </button>
            </div>
            <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:0.875rem; min-width:700px;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border);">
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Người dùng</th>
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Email</th>
                            <th style="padding:10px 12px; text-align:center; color:var(--text-muted); font-weight:600;">Vai trò</th>
                            <th style="padding:10px 12px; text-align:center; color:var(--text-muted); font-weight:600;">Điểm</th>
                            <th style="padding:10px 12px; text-align:center; color:var(--text-muted); font-weight:600;">Trạng thái</th>
                            <th style="padding:10px 12px; text-align:center; color:var(--text-muted); font-weight:600;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <tr><td colspan="6" style="padding:32px; text-align:center; color:var(--text-muted);">Nhấn Tìm kiếm để tải danh sách</td></tr>
                    </tbody>
                </table>
            </div>
            <div id="usersPagination" class="pagination" style="margin-top:16px;"></div>
        </div>

        @* Security Logs Tab *@
        <div id="tab-security" class="admin-tab-content" style="padding:20px; display:none;">
            <div style="display:flex; gap:12px; margin-bottom:16px;">
                <button class="btn btn-primary btn-sm" onclick="loadAdminSecurityLogs(1)"><i class="ti ti-refresh"></i> Tải lại</button>
            </div>
            <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:0.875rem;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border);">
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Thời gian</th>
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Người dùng</th>
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Sự kiện</th>
                            <th style="padding:10px 12px; text-align:left; color:var(--text-muted); font-weight:600;">Chi tiết</th>
                            <th style="padding:10px 12px; text-align:center; color:var(--text-muted); font-weight:600;">IP</th>
                        </tr>
                    </thead>
                    <tbody id="securityLogsBody">
                        <tr><td colspan="5" style="padding:32px; text-align:center; color:var(--text-muted);">Nhấn Tải lại để xem nhật ký</td></tr>
                    </tbody>
                </table>
            </div>
            <div id="securityPagination" class="pagination" style="margin-top:16px;"></div>
        </div>

        @* Permissions Tab *@
        <div id="tab-permissions" class="admin-tab-content" style="padding:20px; display:none;">
            <h3 style="font-size:1rem; margin-bottom:16px;">Ma trận phân quyền</h3>
            <div class="card" style="overflow:hidden;">
                <table style="width:100%; border-collapse:collapse; font-size:0.875rem;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border);">
                            <th style="padding:10px 16px; text-align:left; color:var(--text-muted);">Chức năng</th>
                            <th style="padding:10px 16px; text-align:center; color:var(--text-muted);">Khách</th>
                            <th style="padding:10px 16px; text-align:center; color:var(--text-muted);">Người dùng</th>
                            <th style="padding:10px 16px; text-align:center; color:var(--text-muted);">Điều hành</th>
                            <th style="padding:10px 16px; text-align:center; color:var(--text-muted);">Admin</th>
                        </tr>
                    </thead>
                    <tbody id="permissionMatrix"></tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@* Role Change Modal *@
<div class="modal fade" id="roleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--bg-surface-solid); border:1px solid var(--border); border-radius:var(--radius-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--border);">
                <h5 class="modal-title" style="color:#fff;">Thay đổi vai trò</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom:16px; color:var(--text-secondary); font-size:0.875rem;">Đang thay đổi vai trò cho: <strong id="modalTargetUser"></strong></p>
                <div class="form-group">
                    <label class="form-label">Vai trò mới</label>
                    <select id="newRoleSelect" class="form-select">
                        <option value="User">Người dùng</option>
                        <option value="Moderator">Điều hành viên</option>
                        <option value="Admin">Quản trị viên</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary" id="confirmRoleBtn" onclick="confirmRoleChange()">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@* Ban Modal *@
<div class="modal fade" id="banModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--bg-surface-solid); border:1px solid var(--border); border-radius:var(--radius-lg);">
            <div class="modal-header" style="border-bottom:1px solid var(--border);">
                <h5 class="modal-title" style="color:#fff;">Khóa tài khoản</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom:16px; color:var(--text-secondary); font-size:0.875rem;">Khóa tài khoản: <strong id="banTargetUser"></strong></p>
                <div class="form-group">
                    <label class="form-label">Lý do khóa</label>
                    <textarea id="banReasonInput" class="form-input" rows="3" placeholder="Nhập lý do khóa tài khoản..." style="resize:vertical;"></textarea>
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid var(--border);">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-danger" onclick="confirmBan()" style="background:var(--accent-red); color:#fff; border:none;">
                    <i class="ti ti-ban"></i> Khóa tài khoản
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-tab { padding:12px 20px; background:none; border:none; cursor:pointer; font-size:0.875rem; font-weight:500; color:var(--text-muted); border-bottom:2px solid transparent; white-space:nowrap; display:flex; align-items:center; gap:6px; transition:all 0.15s; }
    .admin-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
    .admin-tab:hover { color:var(--text-primary); }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        let currentRoleUserId = null;
        let currentBanUserId = null;
        let usersPage = 1;
        let roleModal, banModal;
        let growthChart, roleChart;

        document.addEventListener('DOMContentLoaded', () => {
            roleModal = new bootstrap.Modal(document.getElementById('roleModal'));
            banModal = new bootstrap.Modal(document.getElementById('banModal'));
            setupTabs();
            loadDashboard();
            renderPermissionMatrix();
            document.getElementById('userSearch').addEventListener('keydown', e => { if (e.key === 'Enter') loadUsers(1); });
            document.getElementById('roleFilter').addEventListener('change', () => loadUsers(1));
            document.getElementById('banFilter').addEventListener('change', () => loadUsers(1));
        });

        function setupTabs() {
            document.querySelectorAll('.admin-tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
                    document.querySelectorAll('.admin-tab-content').forEach(c => c.style.display = 'none');
                    tab.classList.add('active');
                    document.getElementById(`tab-${tab.dataset.tab}`).style.display = 'block';
                    if (tab.dataset.tab === 'security') loadAdminSecurityLogs(1);
                    else if (tab.dataset.tab === 'users') loadUsers(1);
                    else if (tab.dataset.tab === 'dashboard') loadDashboard();
                });
            });
        }

        async function loadDashboard() {
            try {
                const r = await API.admin.getDashboard({ days: 14 });
                if (!r.success) { Toast.show(r.message || 'Không thể tải thống kê', 'error'); return; }
                const s = r.data;
                renderStatCards(s);
                renderGrowthChart(s);
                renderRoleChart(s);
                renderTopCategories(s.topCategories);
                renderTopUsers(s.topUsers);
            } catch (e) { Toast.show('Lỗi khi tải dữ liệu', 'error'); }
        }

        function renderStatCards(s) {
            const cards = [
                { label:'Tổng người dùng', value:s.totalUsers, sub:`+${s.newUsersToday} hôm nay`, icon:'ti-users', color:'#3fb950' },
                { label:'Tổng bài viết', value:s.totalPosts, sub:`+${s.newPostsToday} hôm nay`, icon:'ti-article', color:'#388bfd' },
                { label:'Tổng bình luận', value:s.totalComments, sub:`+${s.newCommentsToday} hôm nay`, icon:'ti-message', color:'#d29922' },
                { label:'Tài khoản bị khóa', value:s.bannedUsers, sub:`trên ${s.totalUsers} người dùng`, icon:'ti-ban', color:'#f85149' }
            ];
            document.getElementById('statCards').innerHTML = cards.map(c => `
                <div class="card" style="padding:16px; display:flex; align-items:center; gap:12px;">
                    <div style="width:44px; height:44px; border-radius:var(--radius-md); background:${c.color}1a; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="ti ${c.icon}" style="color:${c.color}; font-size:1.25rem;"></i>
                    </div>
                    <div>
                        <div style="font-size:1.375rem; font-weight:700; line-height:1.1;">${(c.value||0).toLocaleString('vi-VN')}</div>
                        <div style="font-size:0.75rem; color:var(--text-muted);">${c.label}</div>
                        <div style="font-size:0.6875rem; color:${c.color};">${c.sub}</div>
                    </div>
                </div>`).join('');
        }

        function renderGrowthChart(s) {
            const labels = (s.userGrowth || []).map(d => { const p = d.date.split('-'); return `${p[2]}/${p[1]}`; });
            const ctx = document.getElementById('growthChart');
            if (growthChart) growthChart.destroy();
            growthChart = new Chart(ctx, {
                type: 'line',
                data: { labels, datasets: [
                    { label:'Người dùng', data:(s.userGrowth||[]).map(d=>d.count), borderColor:'#3fb950', backgroundColor:'#3fb95022', tension:0.3, fill:true, pointRadius:2 },
                    { label:'Bài viết', data:(s.postGrowth||[]).map(d=>d.count), borderColor:'#388bfd', backgroundColor:'#388bfd22', tension:0.3, fill:true, pointRadius:2 },
                    { label:'Bình luận', data:(s.commentGrowth||[]).map(d=>d.count), borderColor:'#d29922', backgroundColor:'#d2992222', tension:0.3, fill:true, pointRadius:2 }
                ]},
                options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
                    scales: { x:{ticks:{color:'#8b949e',font:{size:11}},grid:{color:'#30363d33'}}, y:{beginAtZero:true,ticks:{color:'#8b949e',font:{size:11},precision:0},grid:{color:'#30363d33'}} } }
            });
        }

        function renderRoleChart(s) {
            const ctx = document.getElementById('roleChart');
            if (roleChart) roleChart.destroy();
            roleChart = new Chart(ctx, {
                type: 'doughnut',
                data: { labels:['Người dùng','Điều hành viên','Quản trị viên'],
                    datasets:[{ data:[s.regularUserCount||0,s.moderatorCount||0,s.adminCount||0], backgroundColor:['#388bfd','#d29922','#f85149'], borderWidth:0 }] },
                options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{position:'bottom',labels:{color:'#8b949e',font:{size:11},boxWidth:10}}} }
            });
        }

        function renderTopCategories(cats) {
            const c = document.getElementById('topCategoriesList');
            if (!cats || !cats.length) { c.innerHTML='<p class="text-muted" style="font-size:0.8rem;">Chưa có dữ liệu</p>'; return; }
            const max = Math.max(...cats.map(c=>c.postCount), 1);
            c.innerHTML = cats.map(cat => `<div>
                <div style="display:flex; justify-content:space-between; font-size:0.8125rem; margin-bottom:4px;"><span>${cat.name}</span><span class="text-muted">${cat.postCount} bài</span></div>
                <div style="height:6px; background:var(--bg-surface2); border-radius:4px; overflow:hidden;">
                    <div style="height:100%; width:${(cat.postCount/max)*100}%; background:${cat.color};"></div>
                </div>
            </div>`).join('');
        }

        function renderTopUsers(users) {
            const c = document.getElementById('topUsersList');
            if (!users || !users.length) { c.innerHTML='<p class="text-muted" style="font-size:0.8rem;">Chưa có dữ liệu</p>'; return; }
            c.innerHTML = users.map((u,i) => `<div style="display:flex; align-items:center; gap:10px; padding:8px 0; ${i<users.length-1?'border-bottom:1px solid var(--border);':''}">
                <span style="width:20px; text-align:center; font-size:0.8125rem; color:var(--text-muted); font-weight:600;">${i+1}</span>
                <span class="avatar avatar-sm">${u.username.charAt(0).toUpperCase()}</span>
                <span style="flex:1; font-size:0.875rem;">@@${u.username}</span>
                <span style="font-weight:600; color:var(--accent); font-size:0.875rem;">${u.reputationPoints} điểm</span>
            </div>`).join('');
        }

        async function loadUsers(page = 1) {
            usersPage = page;
            const search = document.getElementById('userSearch').value;
            const role = document.getElementById('roleFilter').value;
            const isBanned = document.getElementById('banFilter').value;
            const tbody = document.getElementById('usersTableBody');
            tbody.innerHTML = `<tr><td colspan="6" style="padding:32px; text-align:center; color:var(--text-muted);"><div class="skeleton" style="height:32px; margin-bottom:8px;"></div><div class="skeleton" style="height:32px;"></div></td></tr>`;
            try {
                const r = await API.admin.getUsers({ page, pageSize:15, search:search||undefined, role:role||undefined, isBanned:isBanned?isBanned==='true':undefined });
                if (!r.success) { tbody.innerHTML = `<tr><td colspan="6" style="padding:20px; text-align:center; color:var(--accent-red);">${r.message}</td></tr>`; return; }
                const users = r.data || [];
                if (!users.length) { tbody.innerHTML = `<tr><td colspan="6" style="padding:32px; text-align:center; color:var(--text-muted);">Không tìm thấy người dùng nào.</td></tr>`; return; }
                tbody.innerHTML = users.map(u => renderUserRow(u)).join('');
                renderUsersPagination(r);
            } catch (e) { tbody.innerHTML = `<tr><td colspan="6" style="padding:20px; text-align:center; color:var(--accent-red);">Lỗi khi tải</td></tr>`; }
        }

        function renderUserRow(u) {
            const statusBadge = u.isBanned
                ? `<span class="badge badge-danger"><i class="ti ti-ban"></i> Đã khóa</span>`
                : `<span class="badge badge-success"><i class="ti ti-check"></i> Hoạt động</span>`;
            const roleColors = { Admin:'var(--accent-red)', Moderator:'var(--accent-orange)', User:'' };
            const roleBadge = u.role !== 'User' ? `<span class="badge" style="background:${roleColors[u.role]}22; color:${roleColors[u.role]}; font-size:0.7rem;">${u.role}</span>` : '';
            return `<tr style="border-bottom:1px solid var(--border); transition:background 0.15s;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background=''">
                <td style="padding:12px;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <span class="avatar avatar-sm">${(u.displayName||u.username).charAt(0).toUpperCase()}</span>
                        <div>
                            <div style="font-weight:500; display:flex; align-items:center; gap:6px;">${u.displayName||u.username} ${roleBadge}</div>
                            <div style="font-size:0.75rem; color:var(--text-muted);">@@${u.username}</div>
                        </div>
                    </div>
                </td>
                <td style="padding:12px; color:var(--text-secondary); font-size:0.8125rem;">${u.email}</td>
                <td style="padding:12px; text-align:center;">${roleBadge || '<span style="color:var(--text-muted); font-size:0.8125rem;">Người dùng</span>'}</td>
                <td style="padding:12px; text-align:center; font-weight:600; color:var(--accent);">${u.reputationPoints}</td>
                <td style="padding:12px; text-align:center;">${statusBadge}</td>
                <td style="padding:12px; text-align:center;">
                    <div style="display:flex; gap:4px; justify-content:center;">
                        <button class="btn btn-ghost btn-sm" onclick="openRoleModal(${u.id}, '${u.username}', '${u.role}')" title="Đổi vai trò"><i class="ti ti-user-cog"></i></button>
                        ${u.isBanned
                            ? `<button class="btn btn-ghost btn-sm" onclick="unbanUser(${u.id})" title="Mở khóa" style="color:var(--accent);"><i class="ti ti-user-check"></i></button>`
                            : `<button class="btn btn-ghost btn-sm" onclick="openBanModal(${u.id}, '${u.username}')" title="Khóa" style="color:var(--accent-red);"><i class="ti ti-ban"></i></button>`}
                    </div>
                </td>
            </tr>`;
        }

        function renderUsersPagination(result) {
            const c = document.getElementById('usersPagination');
            if (!result || result.totalPages <= 1) { c.innerHTML = ''; return; }
            let html = '';
            if (result.hasPreviousPage) html += `<button class="pagination-btn" onclick="loadUsers(${result.page-1})"><i class="ti ti-chevron-left"></i></button>`;
            for (let i=1; i<=result.totalPages; i++) html+=`<button class="pagination-btn ${i===result.page?'active':''}" onclick="loadUsers(${i})">${i}</button>`;
            if (result.hasNextPage) html += `<button class="pagination-btn" onclick="loadUsers(${result.page+1})"><i class="ti ti-chevron-right"></i></button>`;
            c.innerHTML = html;
        }

        async function loadAdminSecurityLogs(page = 1) {
            const tbody = document.getElementById('securityLogsBody');
            tbody.innerHTML = `<tr><td colspan="5" style="padding:32px; text-align:center; color:var(--text-muted);">Đang tải...</td></tr>`;
            try {
                const r = await API.admin.getSecurityLogs({ page, pageSize:50 });
                if (!r.success) { tbody.innerHTML = `<tr><td colspan="5" style="padding:20px; text-align:center; color:var(--accent-red);">${r.message}</td></tr>`; return; }
                const logs = r.data || [];
                if (!logs.length) { tbody.innerHTML = `<tr><td colspan="5" style="padding:32px; text-align:center; color:var(--text-muted);">Chưa có nhật ký nào.</td></tr>`; return; }
                const icons = { ROLE_CHANGED:'ti-user-cog', USER_BANNED:'ti-ban', USER_UNBANNED:'ti-user-check', LOGIN:'ti-login', LOGOUT:'ti-logout', REGISTER:'ti-user-plus' };
                tbody.innerHTML = logs.map(log => {
                    const icon = icons[log.eventType] || 'ti-shield';
                    const color = log.isSuccess ? 'var(--accent)' : 'var(--accent-red)';
                    const time = new Date(log.createdAt).toLocaleString('vi-VN');
                    return `<tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:10px 12px; font-size:0.8125rem; color:var(--text-muted);">${time}</td>
                        <td style="padding:10px 12px; font-size:0.8125rem;">${log.username || '<span style="color:var(--text-muted);">Hệ thống</span>'}</td>
                        <td style="padding:10px 12px;"><span style="color:${color}; font-size:0.8125rem;"><i class="ti ${icon}"></i> ${log.eventType}</span></td>
                        <td style="padding:10px 12px; font-size:0.8125rem; color:var(--text-secondary);">${log.details || ''}</td>
                        <td style="padding:10px 12px; font-size:0.75rem; color:var(--text-muted); text-align:center;">${log.ipAddress || '—'}</td>
                    </tr>`;
                }).join('');
            } catch (e) { tbody.innerHTML = `<tr><td colspan="5" style="padding:20px; text-align:center; color:var(--accent-red);">Lỗi khi tải nhật ký</td></tr>`; }
        }

        function renderPermissionMatrix() {
            const permissions = [
                { feature:'Xem bài viết', guest:true, user:true, mod:true, admin:true },
                { feature:'Đăng bài viết', guest:false, user:true, mod:true, admin:true },
                { feature:'Bình luận', guest:false, user:true, mod:true, admin:true },
                { feature:'Bình chọn', guest:false, user:true, mod:true, admin:true },
                { feature:'Lưu bookmark', guest:false, user:true, mod:true, admin:true },
                { feature:'Ghim/Khóa bài', guest:false, user:false, mod:true, admin:true },
                { feature:'Xóa bình luận người khác', guest:false, user:false, mod:true, admin:true },
                { feature:'Quản lý người dùng', guest:false, user:false, mod:false, admin:true },
                { feature:'Xem thống kê', guest:false, user:false, mod:false, admin:true },
                { feature:'Thay đổi vai trò', guest:false, user:false, mod:false, admin:true },
            ];
            const check = (v) => v ? '<i class="ti ti-check" style="color:var(--accent);"></i>' : '<i class="ti ti-x" style="color:var(--accent-red); opacity:0.5;"></i>';
            document.getElementById('permissionMatrix').innerHTML = permissions.map((p, i) => `
                <tr style="border-bottom:1px solid var(--border); ${i%2===0?'background:rgba(255,255,255,0.01);':''}">
                    <td style="padding:10px 16px; font-size:0.875rem;">${p.feature}</td>
                    <td style="padding:10px 16px; text-align:center;">${check(p.guest)}</td>
                    <td style="padding:10px 16px; text-align:center;">${check(p.user)}</td>
                    <td style="padding:10px 16px; text-align:center;">${check(p.mod)}</td>
                    <td style="padding:10px 16px; text-align:center;">${check(p.admin)}</td>
                </tr>`).join('');
        }

        function openRoleModal(userId, username, currentRole) {
            currentRoleUserId = userId;
            document.getElementById('modalTargetUser').textContent = '@@' + username;
            document.getElementById('newRoleSelect').value = currentRole;
            roleModal.show();
        }

        async function confirmRoleChange() {
            if (!currentRoleUserId) return;
            const newRole = document.getElementById('newRoleSelect').value;
            const btn = document.getElementById('confirmRoleBtn');
            btn.disabled = true; btn.innerHTML = 'Đang lưu...';
            try {
                const r = await API.admin.changeRole(currentRoleUserId, newRole);
                if (r.success) { Toast.show('Đã thay đổi vai trò thành công', 'success'); roleModal.hide(); loadUsers(usersPage); }
                else Toast.show(r.message || 'Không thể thay đổi vai trò', 'error');
            } catch (e) { Toast.show('Lỗi khi thay đổi vai trò', 'error'); }
            finally { btn.disabled = false; btn.innerHTML = 'Xác nhận'; }
        }

        function openBanModal(userId, username) {
            currentBanUserId = userId;
            document.getElementById('banTargetUser').textContent = '@@' + username;
            document.getElementById('banReasonInput').value = '';
            banModal.show();
        }

        async function confirmBan() {
            if (!currentBanUserId) return;
            const reason = document.getElementById('banReasonInput').value.trim() || 'Vi phạm nội quy';
            try {
                const r = await API.admin.banUser(currentBanUserId, reason);
                if (r.success) { Toast.show('Đã khóa tài khoản', 'success'); banModal.hide(); loadUsers(usersPage); }
                else Toast.show(r.message || 'Không thể khóa', 'error');
            } catch (e) { Toast.show('Lỗi khi khóa tài khoản', 'error'); }
        }

        async function unbanUser(userId) {
            if (!confirm('Mở khóa tài khoản này?')) return;
            try {
                const r = await API.admin.unbanUser(userId);
                if (r.success) { Toast.show('Đã mở khóa tài khoản', 'success'); loadUsers(usersPage); }
                else Toast.show(r.message || 'Không thể mở khóa', 'error');
            } catch (e) { Toast.show('Lỗi khi mở khóa', 'error'); }
        }
    </script>
}
