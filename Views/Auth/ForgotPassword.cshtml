@model ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Quên mật khẩu";
}

<div style="width:100%; max-width:400px; padding:24px;">
    <div class="text-center mb-4">
        <a href="/" style="color:var(--accent); text-decoration:none;">
            <img src="/logo2-Photoroom.png" alt="CyberForum" style="height:40px; width:auto;">
        </a>
        <h1 style="font-size:1.375rem; margin-top:12px;">Quên mật khẩu</h1>
        <p class="text-muted" style="font-size:0.875rem;">Nhập email để nhận liên kết đặt lại mật khẩu</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="card text-center" style="padding:32px 24px;">
            <i class="ti ti-mail-check" style="font-size:2.5rem; color:var(--accent); margin-bottom:12px;"></i>
            <p style="font-size:0.9rem; color:var(--text-secondary);">@Model.SuccessMessage</p>
            <a href="/auth/login" class="btn btn-primary w-100 mt-3">Quay lại đăng nhập</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-3" style="border-radius:var(--radius-md); font-size:0.875rem;">
                <i class="ti ti-alert-circle me-2"></i>@Model.ErrorMessage
            </div>
        }

        <form asp-controller="AuthMvc" asp-action="ForgotPassword" method="post" class="card">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <div style="position:relative;">
                    <input asp-for="Email" type="email" class="form-input" placeholder="Nhập địa chỉ email đã đăng ký"
                           style="padding-left:40px;" autocomplete="email">
                    <i class="ti ti-mail" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted);"></i>
                </div>
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100" style="padding:11px;">
                <i class="ti ti-send" style="margin-right:6px;"></i>
                Gửi liên kết đặt lại
            </button>
        </form>

        <p class="text-center mt-4 text-muted" style="font-size:0.875rem;">
            <a href="/auth/login"><i class="ti ti-arrow-left" style="margin-right:4px;"></i>Quay lại đăng nhập</a>
        </p>
    }
</div>
