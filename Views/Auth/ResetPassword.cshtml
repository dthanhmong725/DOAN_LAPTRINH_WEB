@model ResetPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div style="width:100%; max-width:400px; padding:24px;">
    <div class="text-center mb-4">
        <a href="/" style="color:var(--accent); text-decoration:none;">
            <img src="/logo2-Photoroom.png" alt="CyberForum" style="height:40px; width:auto;">
        </a>
        <h1 style="font-size:1.375rem; margin-top:12px;">Đặt lại mật khẩu</h1>
        <p class="text-muted" style="font-size:0.875rem;">Tạo mật khẩu mới cho tài khoản của bạn</p>
    </div>

    @if (Model.IsSuccess)
    {
        <div class="card text-center" style="padding:32px 24px;">
            <i class="ti ti-circle-check" style="font-size:2.5rem; color:var(--accent); margin-bottom:12px;"></i>
            <h2 style="font-size:1.125rem; margin-bottom:8px;">Đặt lại mật khẩu thành công!</h2>
            <p class="text-muted" style="font-size:0.875rem; margin-bottom:16px;">Mật khẩu của bạn đã được cập nhật. Hãy đăng nhập với mật khẩu mới.</p>
            <a href="/auth/login" class="btn btn-primary w-100">Đăng nhập ngay</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger mb-3" style="border-radius:var(--radius-md); font-size:0.875rem;">
                <i class="ti ti-alert-circle me-2"></i>@Model.ErrorMessage
            </div>
        }

        <form asp-controller="AuthMvc" asp-action="ResetPassword" method="post" class="card">
            @Html.AntiForgeryToken()
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label"></label>
                <div style="position:relative;">
                    <i class="ti ti-lock" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; z-index:1;"></i>
                    <input asp-for="NewPassword" type="password" id="passwordInput" class="form-input" placeholder="Nhập mật khẩu mới"
                           style="padding-left:38px; padding-right:38px;" autocomplete="new-password">
                    <button type="button" id="togglePassword"
                            style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-muted); cursor:pointer; padding:4px; z-index:1;">
                        <i class="ti ti-eye"></i>
                    </button>
                </div>
                <div id="strengthContainer"></div>
                <span asp-validation-for="NewPassword" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div style="position:relative;">
                    <i class="ti ti-lock" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; z-index:1;"></i>
                    <input asp-for="ConfirmPassword" type="password" id="confirmInput" class="form-input" placeholder="Xác nhận mật khẩu mới"
                           style="padding-left:38px;" autocomplete="new-password">
                </div>
                <span asp-validation-for="ConfirmPassword" class="form-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100" style="padding:11px;">
                <i class="ti ti-key" style="margin-right:6px;"></i>
                Đặt lại mật khẩu
            </button>
        </form>
    }
</div>

@section Scripts {
    <script src="/js/password-strength.js"></script>
    <script>
        const pwInput = document.getElementById('passwordInput');
        const confirmInput = document.getElementById('confirmInput');
        const strengthContainer = document.getElementById('strengthContainer');
        if (pwInput && strengthContainer) {
            const mgr = new PasswordStrengthManager({
                passwordInput: pwInput,
                confirmInput,
                strengthContainer,
                minScore: 2,
                debounceMs: 100
            });
            mgr.init();
        }
        const toggleBtn = document.getElementById('togglePassword');
        if (toggleBtn && pwInput) {
            toggleBtn.addEventListener('click', () => {
                const isPw = pwInput.type === 'password';
                pwInput.type = isPw ? 'text' : 'password';
                toggleBtn.innerHTML = `<i class="ti ti-eye${isPw ? '-off' : ''}"></i>`;
            });
        }
    </script>
}
