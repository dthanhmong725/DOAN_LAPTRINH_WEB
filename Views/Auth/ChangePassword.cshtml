@model ChangePasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div style="max-width:500px; margin:32px auto;">
    <div class="mb-4">
        <h1 style="font-size:1.5rem; display:flex; align-items:center; gap:10px;">
            <i class="ti ti-key" style="color:var(--accent);"></i> Đổi mật khẩu
        </h1>
        <p class="text-muted" style="font-size:0.875rem;">Cập nhật mật khẩu để bảo vệ tài khoản của bạn</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert" style="background:var(--accent)1a; border:1px solid var(--accent)44; border-radius:var(--radius-md); padding:12px 16px; margin-bottom:20px; color:var(--accent); display:flex; align-items:center; gap:10px;">
            <i class="ti ti-circle-check"></i> @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" style="border-radius:var(--radius-md); font-size:0.875rem;">
            <i class="ti ti-alert-circle me-2"></i>@Model.ErrorMessage
        </div>
    }

    <form asp-controller="AuthMvc" asp-action="ChangePassword" method="post" class="card">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <div style="position:relative;">
                <i class="ti ti-lock" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; z-index:1;"></i>
                <input asp-for="CurrentPassword" type="password" class="form-input" placeholder="Nhập mật khẩu hiện tại"
                       style="padding-left:38px;" autocomplete="current-password">
            </div>
            <span asp-validation-for="CurrentPassword" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="NewPassword" class="form-label"></label>
            <div style="position:relative;">
                <i class="ti ti-lock-open" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; z-index:1;"></i>
                <input asp-for="NewPassword" type="password" id="newPasswordInput" class="form-input" placeholder="Nhập mật khẩu mới"
                       style="padding-left:38px; padding-right:38px;" autocomplete="new-password">
                <button type="button" id="toggleNewPw"
                        style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-muted); cursor:pointer; padding:4px; z-index:1;">
                    <i class="ti ti-eye"></i>
                </button>
            </div>
            <div id="strengthContainer"></div>
            <span asp-validation-for="NewPassword" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div style="position:relative;">
                <i class="ti ti-lock-open" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; z-index:1;"></i>
                <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Xác nhận mật khẩu mới"
                       style="padding-left:38px;" autocomplete="new-password">
            </div>
            <span asp-validation-for="ConfirmPassword" class="form-error"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary" style="padding:10px 24px;">
                <i class="ti ti-check" style="margin-right:6px;"></i>Cập nhật
            </button>
            <a href="/users/settings" class="btn btn-secondary" style="padding:10px 24px;">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="/js/password-strength.js"></script>
    <script>
        const pwInput = document.getElementById('newPasswordInput');
        const strengthContainer = document.getElementById('strengthContainer');
        if (pwInput && strengthContainer) {
            const mgr = new PasswordStrengthManager({ passwordInput: pwInput, strengthContainer, minScore: 2 });
            mgr.init();
        }
        const toggleBtn = document.getElementById('toggleNewPw');
        if (toggleBtn && pwInput) {
            toggleBtn.addEventListener('click', () => {
                const isPw = pwInput.type === 'password';
                pwInput.type = isPw ? 'text' : 'password';
                toggleBtn.innerHTML = `<i class="ti ti-eye${isPw ? '-off' : ''}"></i>`;
            });
        }
    </script>
}
