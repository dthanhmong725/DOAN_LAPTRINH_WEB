@{
    Layout = "_Layout";
    ViewData["Title"] = "Điểm uy tín - CyberForum";
    var username = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
}

<section>
    <h1 style="font-size:1.5rem; margin-bottom:24px; display:flex; align-items:center; gap:10px;">
        <i class="ti ti-star" style="color:var(--accent);"></i> Điểm uy tín của tôi
    </h1>

    @* Stats *@
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(160px, 1fr)); gap:16px; margin-bottom:28px;">
        <div class="card" style="padding:20px; text-align:center;">
            <div style="font-size:2rem; font-weight:700; color:var(--accent);" id="totalPoints">--</div>
            <div style="font-size:0.8125rem; color:var(--text-muted); margin-top:4px;">Tổng điểm</div>
        </div>
        <div class="card" style="padding:20px; text-align:center;">
            <div style="font-size:2rem; font-weight:700; color:var(--text-primary);" id="currentRank">--</div>
            <div style="font-size:0.8125rem; color:var(--text-muted); margin-top:4px;">Cấp độ</div>
        </div>
        <div class="card" style="padding:20px; text-align:center;">
            <div style="font-size:2rem; font-weight:700; color:var(--text-primary);" id="thisMonthPoints">--</div>
            <div style="font-size:0.8125rem; color:var(--text-muted); margin-top:4px;">Điểm tháng này</div>
        </div>
    </div>

    @* History *@
    <h2 style="font-size:1.125rem; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
        <i class="ti ti-history" style="color:var(--accent);"></i> Lịch sử điểm
    </h2>
    <div class="card" style="overflow:hidden;">
        <div id="reputationList">
            <div style="padding:16px;"><div class="skeleton" style="height:40px; margin-bottom:8px;"></div><div class="skeleton" style="height:40px;"></div></div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            try {
                const r = await API.reputation.getHistory({ page: 1, pageSize: 30 });
                if (r.success) {
                    const total = r.data.reduce((s, h) => s + (h.points || 0), 0);
                    const month = new Date().getMonth();
                    const monthPts = r.data.filter(h => new Date(h.createdAt).getMonth() === month).reduce((s, h) => s + (h.points || 0), 0);
                    document.getElementById('totalPoints').textContent = total.toLocaleString('vi-VN');
                    document.getElementById('thisMonthPoints').textContent = (monthPts > 0 ? '+' : '') + monthPts;
                    renderList(r.data);
                }
                // Load profile for rank
                const p = await API.users.getProfile('@Html.Raw(username)');
                if (p.success) document.getElementById('currentRank').textContent = p.data.rank;
            } catch (e) { console.error(e); }
        });

        function renderList(history) {
            const c = document.getElementById('reputationList');
            if (!history || !history.length) { c.innerHTML = '<div style="padding:24px; text-align:center; color:var(--text-muted);">Chưa có lịch sử điểm nào</div>'; return; }
            c.innerHTML = history.map(h => {
                const isPos = (h.points || 0) >= 0;
                const icons = { PostUpvoted:'ti-arrow-up', PostDownvoted:'ti-arrow-down', CommentUpvoted:'ti-message', PostCreated:'ti-edit', DailyLogin:'ti-login', BadgeEarned:'ti-medal', AnswerAccepted:'ti-circle-check' };
                const icon = icons[h.reason] || 'ti-star';
                const labels = { PostUpvoted:'Bài viết được upvote', PostDownvoted:'Bài viết bị downvote', CommentUpvoted:'Bình luận được upvote', PostCreated:'Đăng bài viết mới', DailyLogin:'Đăng nhập hàng ngày', BadgeEarned:'Nhận huy hiệu', AnswerAccepted:'Câu trả lời được chấp nhận' };
                return `<div style="display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--border);">
                    <div style="width:36px; height:36px; border-radius:50%; background:${isPos?'var(--accent)':'var(--accent-red)'}18; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                        <i class="ti ${icon}" style="color:${isPos?'var(--accent)':'var(--accent-red)'};"></i>
                    </div>
                    <div style="flex:1;">
                        <div style="font-size:0.875rem; font-weight:500;">${labels[h.reason] || h.reason || 'Cập nhật điểm'}</div>
                        ${h.relatedPostTitle?`<div style="font-size:0.75rem; color:var(--text-muted); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:300px;">${h.relatedPostTitle}</div>`:''}
                    </div>
                    <div style="font-weight:700; font-size:1rem; color:${isPos?'var(--accent)':'var(--accent-red)'}; flex-shrink:0;">${isPos?'+':''}${h.points}</div>
                    <div style="font-size:0.75rem; color:var(--text-muted); flex-shrink:0;">${new Date(h.createdAt).toLocaleDateString('vi-VN')}</div>
                </div>`;
            }).join('');
        }
    </script>
}
