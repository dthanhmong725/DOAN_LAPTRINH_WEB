@{
    Layout = "_Layout";
    ViewData["Title"] = "Sửa bài viết - CyberForum";
    var postId = ViewData["PostId"]?.ToString() ?? "0";
}

<div style="max-width:860px; margin:0 auto;">
    <h1 style="margin-bottom:20px; display:flex; align-items:center; gap:10px;">
        <i class="ti ti-edit" style="color:var(--accent);"></i> Sửa bài viết
    </h1>

    <form id="editPostForm" class="card">
        <div class="form-group">
            <label class="form-label">Danh mục</label>
            <select name="categoryId" class="form-select" id="categorySelect">
                <option value="">-- Chọn danh mục --</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Tiêu đề</label>
            <input type="text" name="title" class="form-input" id="titleInput"
                   placeholder="Tiêu đề bài viết" minlength="10" maxlength="200">
            <span class="form-hint">10-200 ký tự</span>
        </div>

        <div class="form-group">
            <label class="form-label">Nội dung</label>
            <div id="editor-wrapper" style="border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden;">
                <div id="editor" style="min-height:280px; background:var(--bg-surface2);"></div>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Tags</label>
            <input type="text" name="tags" class="form-input" id="tagsInput" placeholder="tags, cách nhau bởi dấu phẩy">
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <a href="/posts/@postId" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="ti ti-check"></i> Lưu thay đổi
            </button>
        </div>

        <div id="errorMessage" class="form-error mt-3" style="display:none;"></div>
    </form>
</div>

@section Styles {
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
}

@section Scripts {
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        const _postId = @Html.Raw(postId);
        let quillEditor = null;

        document.addEventListener('DOMContentLoaded', async () => {
            quillEditor = new Quill('#editor', {
                theme: 'snow',
                modules: { toolbar: [['bold','italic','underline','strike'],['blockquote','code-block'],[{header:1},{header:2}],[{list:'ordered'},{list:'bullet'}],['link'],['clean']] }
            });

            // Load categories
            try {
                const cr = await API.categories.getAll();
                if (cr.success) {
                    const sel = document.getElementById('categorySelect');
                    cr.data.forEach(cat => { const o = document.createElement('option'); o.value = cat.id; o.textContent = cat.name; sel.appendChild(o); });
                }
            } catch (e) {}

            // Load post data
            try {
                const r = await API.posts.getById(_postId);
                if (r.success) {
                    const post = r.data;
                    document.getElementById('titleInput').value = post.title;
                    document.getElementById('tagsInput').value = (post.tags || []).join(', ');
                    document.getElementById('categorySelect').value = post.category.id;
                    quillEditor.root.innerHTML = post.content;
                    document.title = `Sửa: ${post.title} - CyberForum`;
                }
            } catch (e) { Toast.show('Không thể tải bài viết', 'error'); }

            // Submit
            document.getElementById('editPostForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const errorDiv = document.getElementById('errorMessage');
                const submitBtn = document.getElementById('submitBtn');
                const data = {
                    title: document.getElementById('titleInput').value.trim(),
                    content: quillEditor.root.innerHTML,
                    categoryId: parseInt(document.getElementById('categorySelect').value) || undefined,
                    tags: document.getElementById('tagsInput').value ? document.getElementById('tagsInput').value.split(',').map(t=>t.trim()).filter(Boolean) : []
                };

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="ti ti-loader ti-spin"></i> Đang lưu...';
                errorDiv.style.display = 'none';

                try {
                    const r = await API.posts.update(_postId, data);
                    if (r.success) { Toast.show('Đã lưu thay đổi!', 'success'); window.location.href = `/posts/${_postId}`; }
                    else { errorDiv.textContent = r.message || 'Không thể lưu'; errorDiv.style.display = 'block'; }
                } catch (err) { errorDiv.textContent = err.message || 'Có lỗi xảy ra'; errorDiv.style.display = 'block'; }
                finally { submitBtn.disabled = false; submitBtn.innerHTML = '<i class="ti ti-check"></i> Lưu thay đổi'; }
            });
        });
    </script>
}
