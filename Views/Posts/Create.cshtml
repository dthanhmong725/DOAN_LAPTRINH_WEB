@{
    Layout = "_Layout";
    ViewData["Title"] = "Tạo bài viết - CyberForum";
}

<div style="max-width:860px; margin:0 auto;">
    <h1 style="margin-bottom:20px; display:flex; align-items:center; gap:10px;">
        <i class="ti ti-edit" style="color:var(--accent);"></i> Tạo bài viết mới
    </h1>

    <form id="createPostForm" class="card">
        <div class="form-group">
            <label class="form-label">Danh mục</label>
            <select name="categoryId" class="form-select" required id="categorySelect">
                <option value="">-- Chọn danh mục --</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Tiêu đề</label>
            <input type="text" name="title" class="form-input" placeholder="Nhập tiêu đề bài viết mô tả"
                   required minlength="10" maxlength="200" id="titleInput">
            <span class="form-hint">10-200 ký tự</span>
        </div>

        <div class="form-group">
            <label class="form-label">Nội dung</label>
            <div id="editor-wrapper" style="border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden;">
                <div id="editor" style="min-height:280px; background:var(--bg-surface2);"></div>
            </div>
            <span class="form-hint">Tối thiểu 50 ký tự (sau khi loại thẻ HTML)</span>
        </div>

        <div class="form-group">
            <label class="form-label">Tags (tùy chọn)</label>
            <input type="text" name="tags" class="form-input"
                   placeholder="Nhập tags, cách nhau bởi dấu phẩy (ví dụ: xss, sql-injection, owasp)" id="tagsInput">
            <span class="form-hint">Tối đa 5 tags, cách nhau bởi dấu phẩy</span>
        </div>

        <div class="form-group">
            <label class="form-label"><i class="ti ti-paperclip"></i> Tài liệu đính kèm (tùy chọn)</label>
            <div id="uploadDropZone" style="border:2px dashed var(--border); border-radius:var(--radius-md); padding:24px; text-align:center; background:var(--bg-surface2); cursor:pointer; transition:all 0.2s;"
                 onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
                <i class="ti ti-cloud-upload" style="font-size:2rem; color:var(--accent); margin-bottom:8px; display:block;"></i>
                <div style="font-size:0.9rem; font-weight:500; margin-bottom:4px;">Kéo thả file hoặc bấm để chọn</div>
                <div style="font-size:0.75rem; color:var(--text-muted);">PDF, Word, Excel, hình ảnh, video, code files... (tối đa 50MB mỗi file)</div>
                <input type="file" id="postFileInput" multiple style="display:none"
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.zip,.rar,.7z,.jpg,.jpeg,.png,.gif,.webp,.svg,.mp4,.webm,.py,.js,.ts,.java,.cpp,.c,.cs,.php,.go,.rs,.rb,.sh,.json,.xml,.yaml,.yml,.md">
            </div>
            <div id="uploadedFiles" style="margin-top:12px; display:flex; flex-direction:column; gap:6px;"></div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4">
            <a href="/" class="btn btn-secondary">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <span class="btn-text"><i class="ti ti-send"></i> Đăng bài</span>
            </button>
        </div>

        <div id="errorMessage" class="form-error mt-3" style="display:none;"></div>
    </form>
</div>

@section Styles {
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
}

@section Scripts {
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        let quillEditor = null;
        const uploadedAttachments = [];

        function stripHtml(html) { const t = document.createElement('div'); t.innerHTML = html; return t.textContent || t.innerText || ''; }
        function getFileIcon(filename) {
            const ext = (filename.split('.').pop() || '').toLowerCase();
            const m = { pdf:'ti-file-text',doc:'ti-file-text',docx:'ti-file-text',xls:'ti-file-spreadsheet',xlsx:'ti-file-spreadsheet',zip:'ti-file-zip',rar:'ti-file-zip',jpg:'ti-photo',jpeg:'ti-photo',png:'ti-photo',gif:'ti-photo',mp4:'ti-video',py:'ti-code',js:'ti-code',ts:'ti-code',cs:'ti-code',json:'ti-code',txt:'ti-file' };
            return m[ext] || 'ti-file';
        }
        function formatFileSize(b) { if(b<1024)return b+' B'; if(b<1048576)return (b/1024).toFixed(1)+' KB'; return (b/1048576).toFixed(1)+' MB'; }

        function renderUploadedFiles() {
            const c = document.getElementById('uploadedFiles');
            c.innerHTML = uploadedAttachments.map((att, i) => `
                <div style="display:flex; align-items:center; gap:10px; padding:8px 12px; background:var(--bg-surface); border:1px solid var(--border); border-radius:var(--radius-sm);">
                    <i class="ti ${getFileIcon(att.fileName)}" style="color:var(--accent); font-size:1.2rem;"></i>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:0.85rem; font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${att.fileName}</div>
                        <div style="font-size:0.7rem; color:var(--text-muted);">${formatFileSize(att.fileSize)}</div>
                    </div>
                    <button type="button" onclick="removeAttachment(${i})" style="background:transparent; border:none; color:var(--accent-red); cursor:pointer; padding:4px;"><i class="ti ti-x"></i></button>
                </div>`).join('');
        }
        function removeAttachment(i) { uploadedAttachments.splice(i, 1); renderUploadedFiles(); }

        async function handleFiles(files) {
            for (const file of files) {
                if (file.size > 50 * 1024 * 1024) { Toast.show(`File "${file.name}" quá lớn (tối đa 50MB)`, 'warning'); continue; }
                const fd = new FormData(); fd.append('file', file);
                try {
                    const r = await API.upload.file(fd);
                    if (r.success) { uploadedAttachments.push({ fileName: file.name, fileSize: file.size, url: r.data.url }); renderUploadedFiles(); Toast.show(`Đã tải lên ${file.name}`, 'success'); }
                    else Toast.show(r.message || `Lỗi tải lên ${file.name}`, 'error');
                } catch (e) { Toast.show(`Lỗi tải lên ${file.name}: ${e.message}`, 'error'); }
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            // File upload
            const dropZone = document.getElementById('uploadDropZone');
            const fileInput = document.getElementById('postFileInput');
            dropZone.addEventListener('click', () => fileInput.click());
            dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.style.borderColor = 'var(--accent)'; dropZone.style.background = 'rgba(0,229,160,0.05)'; });
            dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = 'var(--border)'; dropZone.style.background = 'var(--bg-surface2)'; });
            dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.style.borderColor = 'var(--border)'; dropZone.style.background = 'var(--bg-surface2)'; handleFiles(e.dataTransfer.files); });
            fileInput.addEventListener('change', (e) => { handleFiles(e.target.files); e.target.value = ''; });

            // Quill editor
            quillEditor = new Quill('#editor', {
                theme: 'snow',
                placeholder: 'Viết nội dung bài viết tại đây...',
                modules: { toolbar: [['bold','italic','underline','strike'],['blockquote','code-block'],[{header:1},{header:2}],[{list:'ordered'},{list:'bullet'}],['link','image'],['clean']] }
            });

            // Load categories
            try {
                const r = await API.categories.getAll();
                if (r.success) {
                    const sel = document.getElementById('categorySelect');
                    r.data.forEach(cat => { const o = document.createElement('option'); o.value = cat.id; o.textContent = cat.name; sel.appendChild(o); });
                }
            } catch (e) { Toast.show('Không thể tải danh mục', 'error'); }

            // Submit
            document.getElementById('createPostForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const content = quillEditor.root.innerHTML;
                const plainText = stripHtml(content).trim();
                const errorDiv = document.getElementById('errorMessage');
                const submitBtn = document.getElementById('submitBtn');

                if (plainText.length < 50) { errorDiv.textContent = 'Nội dung phải có ít nhất 50 ký tự'; errorDiv.style.display = 'block'; return; }
                const title = document.getElementById('titleInput').value.trim();
                if (title.length < 10 || title.length > 200) { errorDiv.textContent = 'Tiêu đề phải từ 10 đến 200 ký tự'; errorDiv.style.display = 'block'; return; }

                const tags = document.getElementById('tagsInput').value
                    ? document.getElementById('tagsInput').value.split(',').map(t=>t.trim()).filter(Boolean).slice(0,5) : [];
                const data = {
                    title, content,
                    categoryId: parseInt(document.getElementById('categorySelect').value),
                    tags,
                    attachments: uploadedAttachments.map(a => ({ fileName: a.fileName, fileUrl: a.url, fileSize: a.fileSize }))
                };

                submitBtn.disabled = true;
                submitBtn.querySelector('.btn-text').innerHTML = '<i class="ti ti-loader ti-spin"></i> Đang đăng...';
                errorDiv.style.display = 'none';

                try {
                    const r = await API.posts.create(data);
                    if (r.success) { Toast.show('Bài viết đã được đăng thành công!', 'success'); window.location.href = `/posts/${r.data.id}`; }
                    else { errorDiv.textContent = r.message || 'Không thể tạo bài viết'; errorDiv.style.display = 'block'; }
                } catch (err) { errorDiv.textContent = err.message || 'Có lỗi xảy ra'; errorDiv.style.display = 'block'; }
                finally { submitBtn.disabled = false; submitBtn.querySelector('.btn-text').innerHTML = '<i class="ti ti-send"></i> Đăng bài'; }
            });
        });
    </script>
}
