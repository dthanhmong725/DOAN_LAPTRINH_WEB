@{
    Layout = "_Layout";
    ViewData["Title"] = "CyberForum - Diễn đàn An ninh mạng";
    ViewData["Description"] = "Diễn đàn cộng đồng an ninh mạng Việt Nam - Chia sẻ kiến thức về Pentest, Malware, Web Security, Network, Crypto, SOC, Reverse Engineering";
}

@* Hero Section *@
<section class="hero" style="text-align:center; padding:32px 0 24px;">
    <h1 style="font-size:2rem; margin-bottom:8px;">
        Chào mừng đến <span style="color:var(--accent);">CyberForum</span>
    </h1>
    <p style="color:var(--text-muted); max-width:560px; margin:0 auto 20px; font-size:0.9375rem;">
        Cộng đồng an ninh mạng Việt Nam. Chia sẻ kiến thức, thảo luận kỹ thuật và học hỏi cùng nhau.
    </p>
    <div class="d-flex gap-2 justify-content-center">
        @if (!User.Identity!.IsAuthenticated)
        {
            <a href="/auth/register" class="btn btn-primary btn-lg">Tham gia cộng đồng</a>
        }
        <a href="/categories" class="btn btn-secondary btn-lg">Khám phá chủ đề</a>
    </div>
</section>

@* Categories Grid *@
<section style="margin-bottom:28px;">
    <h2 style="margin-bottom:14px; display:flex; align-items:center; gap:8px;">
        <i class="ti ti-category" style="color:var(--accent);"></i> Danh mục
    </h2>
    <div id="categoriesGrid" class="d-flex" style="gap:12px; flex-wrap:wrap;"></div>
</section>

@* Recent Posts *@
<section>
    <div class="d-flex justify-content-between align-items-center" style="margin-bottom:14px;">
        <h2 style="display:flex; align-items:center; gap:8px; margin:0;">
            <i class="ti ti-flame" style="color:var(--accent);"></i> Bài viết mới nhất
        </h2>
        <select id="sortSelect" class="form-select" style="width:auto; padding:6px 12px;">
            <option value="">Mới nhất</option>
            <option value="views">Xem nhiều nhất</option>
            <option value="comments">Bình luận nhiều nhất</option>
            <option value="oldest">Cũ nhất</option>
        </select>
    </div>
    <div id="postsList">
        <div class="skeleton" style="height:110px; margin-bottom:12px;"></div>
        <div class="skeleton" style="height:110px; margin-bottom:12px;"></div>
        <div class="skeleton" style="height:110px;"></div>
    </div>
    <div id="pagination" class="pagination"></div>
</section>

@section Scripts {
    @{
        var isAuth = User.Identity!.IsAuthenticated;
    }
    <script>
        const _isAuthenticated = @(isAuth ? "true" : "false");

        document.addEventListener('DOMContentLoaded', async () => {
            await loadCategories();
            await loadPosts();
            document.getElementById('sortSelect').addEventListener('change', (e) => loadPosts(1, e.target.value));
        });

        async function loadCategories() {
            try {
                const result = await API.categories.getAll();
                if (result.success) renderCategoriesGrid(result.data);
            } catch (e) { console.error('Lỗi tải danh mục:', e); }
        }

        function renderCategoriesGrid(categories) {
            const grid = document.getElementById('categoriesGrid');
            grid.innerHTML = categories.map(cat => {
                const iconName = cat.icon.startsWith('ti-') ? cat.icon : 'ti-' + cat.icon;
                return `<a href="/categories/${cat.slug}" class="card" style="flex:1; min-width:160px; text-decoration:none; color:inherit; padding:14px; border-radius:var(--radius-md);">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
                        <div style="width:36px; height:36px; border-radius:var(--radius-sm); background:${cat.color}18; display:flex; align-items:center; justify-content:center;">
                            <i class="ti ${iconName}" style="color:${cat.color}; font-size:1.125rem;"></i>
                        </div>
                        <div>
                            <h3 style="font-size:0.875rem; margin-bottom:1px;">${cat.name}</h3>
                            <span style="font-size:0.75rem; color:var(--text-muted);">${cat.postCount} bài</span>
                        </div>
                    </div>
                    ${cat.description ? `<p style="font-size:0.75rem; color:var(--text-muted); line-height:1.4;">${cat.description}</p>` : ''}
                </a>`;
            }).join('');
        }

        let currentPage = 1;
        async function loadPosts(page = 1, sortBy = '') {
            currentPage = page;
            const sort = sortBy || document.getElementById('sortSelect').value;
            try {
                const result = await API.posts.getAll({ page, pageSize: 10, sortBy: sort });
                renderPosts(result.data);
                renderPagination(result);
            } catch (e) {
                document.getElementById('postsList').innerHTML = '<p class="text-muted">Không thể tải bài viết</p>';
            }
        }

        function renderPosts(posts) {
            const container = document.getElementById('postsList');
            if (!posts || !posts.length) {
                container.innerHTML = `<div class="empty-state">
                    <i class="ti ti-inbox"></i><h3>Chưa có bài viết nào</h3>
                    <p>Hãy là người đầu tiên chia sẻ kiến thức!</p>
                    ${_isAuthenticated ? '<a href="/posts/create" class="btn btn-primary mt-3">Tạo bài viết</a>' : ''}
                </div>`;
                return;
            }
            container.innerHTML = posts.map(post => `
                <article class="post-card ${post.isPinned ? 'pinned' : ''}">
                    <div class="post-votes">
                        <button class="vote-btn ${post.userVote === 1 ? 'upvoted' : ''}" onclick="votePost(${post.id}, true)"><i class="ti ti-arrow-up"></i></button>
                        <span class="vote-count ${(post.upvoteCount - post.downvoteCount) > 0 ? 'positive' : (post.upvoteCount - post.downvoteCount) < 0 ? 'negative' : ''}">${post.upvoteCount - post.downvoteCount}</span>
                        <button class="vote-btn ${post.userVote === -1 ? 'downvoted' : ''}" onclick="votePost(${post.id}, false)"><i class="ti ti-arrow-down"></i></button>
                    </div>
                    <div class="post-content">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <a href="/posts/${post.id}" class="post-title" style="text-decoration:none;">
                                ${post.isPinned ? '<span class="badge badge-success" style="margin-right:6px; font-size:0.625rem;"><i class="ti ti-pinned"></i> Đã ghim</span>' : ''}${post.title}
                            </a>
                            ${post.isLocked ? '<i class="ti ti-lock" style="color:var(--text-muted); flex-shrink:0;"></i>' : ''}
                        </div>
                        <div class="post-meta">
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar avatar-sm">${(post.authorUsername||'U').charAt(0).toUpperCase()}</div>
                                <a href="/users/profile?username=${post.authorUsername}" style="color:inherit; text-decoration:none;">${post.authorUsername}${post.authorRole && post.authorRole !== 'User' ? RoleGuard.renderRoleBadge(post.authorRole) : ''}</a>
                            </div>
                            <span class="post-meta-item"><i class="ti ti-clock"></i> ${formatTimeAgo(post.createdAt)}</span>
                            <span class="post-meta-item"><i class="ti ti-eye"></i> ${post.viewCount}</span>
                            <span class="post-meta-item"><i class="ti ti-message"></i> ${post.commentCount}</span>
                            <a href="/categories/${post.categorySlug}" class="category-tag ${post.categorySlug}" style="text-decoration:none;">${post.categoryName}</a>
                        </div>
                        ${post.tags && post.tags.length ? `<div class="post-tags">${post.tags.map(t=>`<span class="post-tag">${t}</span>`).join('')}</div>` : ''}
                    </div>
                    <button class="btn btn-ghost bookmark-btn ${post.isBookmarked ? 'bookmarked' : ''}" onclick="toggleBookmark(${post.id}, this)"
                        style="align-self:flex-start; color:${post.isBookmarked ? 'var(--accent)' : ''};">
                        <i class="${post.isBookmarked ? 'ti ti-bookmark-filled' : 'ti ti-bookmark'}"></i>
                    </button>
                </article>`).join('');
        }

        function renderPagination(result) {
            const c = document.getElementById('pagination');
            if (!result || result.totalPages <= 1) { c.innerHTML = ''; return; }
            let html = '';
            if (result.hasPreviousPage) html += `<button class="pagination-btn" onclick="loadPosts(${result.page-1})"><i class="ti ti-chevron-left"></i></button>`;
            for (let i = 1; i <= result.totalPages; i++) {
                if (i===1||i===result.totalPages||(i>=result.page-1&&i<=result.page+1)) html+=`<button class="pagination-btn ${i===result.page?'active':''}" onclick="loadPosts(${i})">${i}</button>`;
                else if (i===result.page-2||i===result.page+2) html+=`<span style="color:var(--text-muted);padding:0 4px;">...</span>`;
            }
            if (result.hasNextPage) html += `<button class="pagination-btn" onclick="loadPosts(${result.page+1})"><i class="ti ti-chevron-right"></i></button>`;
            c.innerHTML = html;
        }

        async function votePost(postId, isUpvote) {
            if (!_isAuthenticated) { Toast.show('Vui lòng đăng nhập để bình chọn', 'warning'); return; }
            try { await API.posts.vote(postId, isUpvote); await loadPosts(currentPage); }
            catch (e) { Toast.show(e.message, 'error'); }
        }

        const _bkDebounce = new Map();
        async function toggleBookmark(postId, btn) {
            if (!_isAuthenticated) { Toast.show('Vui lòng đăng nhập để lưu bài', 'warning'); return; }
            const now = Date.now();
            if (now - (_bkDebounce.get(postId)||0) < 300) return;
            _bkDebounce.set(postId, now);
            const isBk = btn.classList.contains('bookmarked');
            const setUI = (active) => {
                btn.classList.toggle('bookmarked', active);
                btn.style.color = active ? 'var(--accent)' : '';
                btn.querySelector('i').className = active ? 'ti ti-bookmark-filled' : 'ti ti-bookmark';
            };
            setUI(!isBk);
            try {
                const r = await API.bookmarks.toggle(postId);
                if (!r.success) { setUI(isBk); Toast.show(r.message||'Có lỗi xảy ra', 'error'); }
                else Toast.show(r.data ? 'Đã lưu bài viết' : 'Đã bỏ lưu', 'success');
            } catch { setUI(isBk); Toast.show('Có lỗi xảy ra', 'error'); }
        }

        function formatTimeAgo(d) {
            const s = Math.floor((new Date()-new Date(d))/1000);
            if (s<60) return 'vài giây trước';
            if (s<3600) return `${Math.floor(s/60)} phút trước`;
            if (s<86400) return `${Math.floor(s/3600)} giờ trước`;
            if (s<604800) return `${Math.floor(s/86400)} ngày trước`;
            return new Date(d).toLocaleDateString('vi-VN',{day:'numeric',month:'short',year:'numeric'});
        }
    </script>
}
