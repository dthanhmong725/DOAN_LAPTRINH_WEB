@{
    Layout = "_Layout";
    ViewData["Title"] = "Upload tài liệu - CyberForum";
}

<div style="max-width:600px; margin:40px auto; text-align:center;">
    <div class="card" style="padding:40px;">
        <div style="font-size:3rem; color:var(--accent); margin-bottom:16px;"><i class="ti ti-upload"></i></div>
        <h1 style="font-size:1.5rem; margin-bottom:12px;">Upload tài liệu</h1>
        <p style="color:var(--text-muted); margin-bottom:24px; line-height:1.6;">
            Tính năng upload tài liệu đã được tích hợp trực tiếp vào trang <strong>Tạo bài viết</strong> và <strong>Sửa bài viết</strong>.
            Bạn có thể đính kèm PDF, hình ảnh, video, file code... ngay khi viết bài.
        </p>
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
            <a href="/posts/create" class="btn btn-primary">
                <i class="ti ti-edit"></i> Tạo bài viết mới
            </a>
            <a href="/users/profile" class="btn btn-secondary">
                <i class="ti ti-user"></i> Về trang cá nhân
            </a>
        </div>
    </div>
</div>
